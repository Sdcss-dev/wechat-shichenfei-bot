# 企业微信配置
CORP_ID=你的企业微信CorpID
CORP_SECRET=你的企业微信Secret
AGENT_ID=你的自建应用AgentId
TOKEN=你在管理后台设置的Token
ENCODING_AES_KEY=你在管理后台生成的EncodingAESKey(43位)

# Claude API 配置
ANTHROPIC_API_KEY=你的APIKey
ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
ANTHROPIC_MODEL=mimo-v2.5-pro

# 服务配置
PORT=3000
